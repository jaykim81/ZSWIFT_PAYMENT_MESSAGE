<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:code="sap.ui.codeeditor">
    <Dialog
        title="전송 시뮬레이션 미리보기"
        contentWidth="70%"
        resizable="true"
        draggable="true"
        stretchOnPhone="true">
        <content>
            <code:CodeEditor
                type="xml"
                width="100%"
                height="60vh"
                editable="false"
                lineNumbers="true"
                colorTheme="default" />
        </content>
        <beginButton>
            <Button text="복사" icon="sap-icon://copy" press="onCopy" />
        </beginButton>
        <endButton>
            <Button text="닫기" press="onClose" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
